# ─────────────────────────────────────────────────────────────
# APPLICATION
# ─────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
API_VERSION=v1
API_BASE_URL=http://localhost:3000

# ─────────────────────────────────────────────────────────────
# PostgreSQL + PostGIS
# ─────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=pickup_dropoff
DB_USER=postgres
DB_PASSWORD=your_secure_password_here
DB_SSL=false
# Connection pool
DB_POOL_MIN=2
DB_POOL_MAX=20

# ─────────────────────────────────────────────────────────────
# REDIS
# ─────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
# TTL in seconds
REDIS_DRIVER_LOCATION_TTL=30
REDIS_SESSION_TTL=86400

# ─────────────────────────────────────────────────────────────
# JWT
# ─────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=replace_with_64+_char_random_secret
JWT_REFRESH_SECRET=replace_with_64+_char_random_secret_different
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─────────────────────────────────────────────────────────────
# ENCRYPTION (AES-256 for sensitive fields like bank details)
# ─────────────────────────────────────────────────────────────
ENCRYPTION_KEY=replace_with_exactly_32_char_key!!

# ─────────────────────────────────────────────────────────────
# PRICING & CURRENCIES
# ─────────────────────────────────────────────────────────────
# Supported: BHD, SAR, AED, USD
DEFAULT_CURRENCY=BHD
BASE_FARE_BHD=1.00
PER_KM_FARE_BHD=0.30
BASE_FARE_SAR=10.00
PER_KM_FARE_SAR=2.50
BASE_FARE_AED=5.00
PER_KM_FARE_AED=1.50
PLATFORM_FEE_PERCENT=15
DRIVER_PAYOUT_PERCENT=85

# ─────────────────────────────────────────────────────────────
# DISPATCH ENGINE
# ─────────────────────────────────────────────────────────────
DISPATCH_RADIUS_KM=5
DISPATCH_MAX_RETRIES=3
DISPATCH_RETRY_INTERVAL_MS=15000
DISPATCH_DRIVER_RESPONSE_TIMEOUT_MS=30000

# ─────────────────────────────────────────────────────────────
# RATE LIMITING
# ─────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# ─────────────────────────────────────────────────────────────
# LOGGING
# ─────────────────────────────────────────────────────────────
LOG_LEVEL=info
LOG_PRETTY=true
