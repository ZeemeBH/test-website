{
  "name": "pickup-dropoff-api",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:migrate": "wrangler d1 execute pickup-dropoff-db --file=src/db/schema.sql --remote",
    "db:migrate:local": "wrangler d1 execute pickup-dropoff-db --file=src/db/schema.sql --local",
    "db:seed": "wrangler d1 execute pickup-dropoff-db --file=src/db/seed.sql --remote"
  },
  "dependencies": {
    "hono": "^4.4.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240529.0",
    "wrangler": "^3.60.0",
    "typescript": "^5.5.0"
  }
}
